{
  "name": "@xpert-ai/chatkit-angular",
  "version": "0.0.1",
  "description": "Angular bindings for Xpert Chatkit",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/fesm2022/xpert-ai-chatkit-angular.mjs",
  "types": "./dist/types/xpert-ai-chatkit-angular.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node \"$npm_execpath\" --filter @xpert-ai/chatkit-web-component... build",
    "build": "ng-packagr -p ng-package.json",
    "predev": "node \"$npm_execpath\" --filter @xpert-ai/chatkit-web-component... build",
    "dev": "ng-packagr -p ng-package.json -w",
    "pretype-check": "node \"$npm_execpath\" --filter @xpert-ai/chatkit-web-component... build",
    "type-check": "tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "@xpert-ai/chatkit-types": "workspace:~",
    "@xpert-ai/chatkit-web-component": "workspace:~",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@angular/core": ">=17 <22"
  },
  "devDependencies": {
    "@angular/compiler": "21.1.4",
    "@angular/compiler-cli": "21.1.4",
    "@angular/core": "21.1.4",
    "ng-packagr": "21.1.0",
    "rxjs": "^7.8.2",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "chatkit",
    "angular",
    "xpert"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xpert-ai/chatkit-js"
  }
}
